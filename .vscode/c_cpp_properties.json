{
    "configurations": [
        {
            "name": "Win32-MSYS2",
            "includePath": [
                "${workspaceFolder}/**",
                "D:/msys2/mingw64/include/**",
                "D:/msys2/mingw64/lib/gcc/x86_64-w64-mingw32/*/include/**",
                "D:/c_libs/SDL3/x86_64-w64-mingw32/include"
            ],
            "defines": [
                "_DEBUG",
                "UNICODE",
                "_UNICODE"
            ],
            "compilerPath": "D:/msys2/mingw64/bin/gcc.exe",
            "cStandard": "c17",
            "cppStandard": "gnu++17",
            "intelliSenseMode": "windows-gcc-x64",
            "compilerArgs": [
                "-fexec-charset=GBK"
            ],
            "browse": {
                "path": [
                    "${workspaceFolder}",
                    "D:/msys2/mingw64/include",
                    "D:/c_libs/SDL3/x86_64-w64-mingw32/include"
                ],
                "limitSymbolsToIncludedHeaders": true,
                "databaseFilename": ""
            }
        }
    ],
    "version": 4
}
